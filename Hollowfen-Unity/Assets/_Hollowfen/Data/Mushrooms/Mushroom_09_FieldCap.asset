  m_Script: {fileID: 11500000, guid: 8fbeeb9dfd308426da67b82545b339a0, type: 3}
  m_Name: Mushroom_09_FieldCap
  m_EditorClassIdentifier: Assembly-CSharp::Hollowfen.Data.MushroomFieldGuideData
  _id: fieldCap
  _commonName: Field Cap
  _latinName: Marasmius oreades
  _edibility: 0
  _edibilityLabel: "Edible \u2014 meadow"
  _description: 'A small tan meadow mushroom known outside Hollowfen as the fairy
    ring champignon. It looks ordinary until you notice the pattern: neat troops
    and rings in short grass, caps that dry from honey-brown to pale buff, and a
    wiry stem that bends before it breaks. Bram teaches this one first because it
    rewards patience instead of luck.'
  _idFeatures:
  - Tan to buff cap, often slightly darker in the center
  - Widely spaced pale gills, not dark chocolate gills
  - Tough, wiry stem with no ring and no cup-like volva
  - Often grows in arcs or fairy rings through open grass
  _habitat: Clearings, pasture edges, and short grass around the village
  _season: Late summer through autumn
  _lookalikes: Small brown lawn mushrooms and toxic little brown mushrooms. Skip
    any specimen with crowded rusty gills, a fragile stem, or a base you cannot inspect.
  _notes: 'A humble first find with a useful lesson: habitat matters. Bram calls
    them common. Marra calls them breakfast when the village still has butter.'
  _photo: {fileID: 21300000, guid: 02ef72fd1da97490290c144f842d66eb, type: 3}
  _photoCredit: 
  _worldPrefab: {fileID: 7479168876297052834, guid: 902561bbde9cf4756b5585d73161a7a1, type: 3}
