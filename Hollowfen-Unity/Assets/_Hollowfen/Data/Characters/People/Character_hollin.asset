  m_Name: Character_hollin
  m_EditorClassIdentifier: Assembly-CSharp::Hollowfen.Data.CharacterProfileData
  _id: hollin
  _characterName: Hollin
  _role: Traveler / deep-wood companion
  _age: Late twenties
  _home: On the road; a guest at the Crooked Pintle
  _work: Travel and deep-wood exploration
  _keepsake: Old pages folded into oilcloth
  _tagline: The quiet traveler following a family path that remembers feet better
    than names.
  _leadParagraph: Hollin is pale, dark-haired, and contained, a traveler who arrives
    with one satchel and no interest in buying or selling.
  _backgroundParagraph: She has walked through three villages looking for Wren and
    for a place her grandmother named when she thought no one was listening.
  _perspectiveParagraph: Hollin listens for what paths, old pages, and careful silences
    retain. She speaks sparingly and enters remembered places kindly.
  _kitItems: []
  _heroPortrait: {fileID: 0}
  _pullquote: I think the path remembers feet better than names.
