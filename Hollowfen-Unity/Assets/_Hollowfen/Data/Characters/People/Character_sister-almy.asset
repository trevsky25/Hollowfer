  m_Name: Character_sister-almy
  m_EditorClassIdentifier: Assembly-CSharp::Hollowfen.Data.CharacterProfileData
  _id: sister-almy
  _characterName: Sister Almy
  _role: Vine-tender / cultivation mentor
  _age: Late fifties to early sixties
  _home: Almy's garden and the chapel garden
  _work: Cultivation, medicinal lore, and teaching
  _keepsake: The old seedbook
  _tagline: The severe teacher whose hands remember what the village tried to forget.
  _leadParagraph: Sister Almy is slight, wiry, and direct, a vine-tender whose weathered
    hands make every cultivation lesson look precise and necessary.
  _backgroundParagraph: She recognizes knowledge in Wren that the younger woman did
    not know she carried and begins teaching her how to read rot, feed it, and leave
    enough behind.
  _perspectiveParagraph: Almy treats patience as a discipline and names as responsibilities.
    Most useful lessons sound like warnings when she gives them.
  _kitItems: []
  _heroPortrait: {fileID: 0}
  _pullquote: Do not rush growth. Rushed mushrooms teach regret.
  _displayNameId: character.sister_almy.name
  _descriptionId: character.sister_almy.lead
  _sortOrder: 4
  _category: 0
  _edition: 05 / SISTER ALMY
  _previewScale: 1
