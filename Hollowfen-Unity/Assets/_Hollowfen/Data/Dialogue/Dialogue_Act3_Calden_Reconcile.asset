  m_Script: {fileID: 11500000, guid: 00c9c9bb92b3b44fb84ca335c48467d8, type: 3}
  m_Name: Dialogue_Act3_Calden_Reconcile
  m_EditorClassIdentifier: Assembly-CSharp::Hollowfen.Dialogue.DialogueData
  _id: act3.calden.reconcile
  _lines:
  - speaker: Calden
    text: The church helped bury this knowledge.
    isCloseup: 1
    voiceClip: {fileID: 8300000, guid: 07149c6844b3b466f9c8e07552fc6502, type: 3}
  - speaker: Wren
    text: Because it was wicked?
    isCloseup: 0
    voiceClip: {fileID: 8300000, guid: 92a09af0220f04dc6a491440ed0e49da, type: 3}
  - speaker: Calden
    text: 'Because it was useful to people who were not powerful.


      I will
      not bless what I do not understand. But I will no longer stand in its way.'
    isCloseup: 1
    voiceClip: {fileID: 8300000, guid: 21a7988e4e7bc4056964739274ae61e9, type: 3}
  - speaker: Wren
    text: That is a gate opening.
    isCloseup: 0
    voiceClip: {fileID: 8300000, guid: 49da6cf6827214e0e8190ea1a1a7517c, type: 3}
  - speaker: Calden
    text: Here is the key to the garden gate. It should have been given long ago.
    isCloseup: 0
    voiceClip: {fileID: 8300000, guid: f3f8ec0c66f7948babd7859cc42e6e0e, type: 3}
