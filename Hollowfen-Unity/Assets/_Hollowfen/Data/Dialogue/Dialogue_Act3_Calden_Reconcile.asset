  m_Script: {fileID: 11500000, guid: 00c9c9bb92b3b44fb84ca335c48467d8, type: 3}
  m_Name: Dialogue_Act3_Calden_Reconcile
  m_EditorClassIdentifier: Assembly-CSharp::Hollowfen.Dialogue.DialogueData
  _id: act3.calden.reconcile
  _lines:
  - speaker: Calden
    text: 'The church helped bury this knowledge.'
    isCloseup: 1
  - speaker: Wren
    text: 'Because it was wicked?'
    isCloseup: 0
  - speaker: Calden
    text: 'Because it was useful to people who were not powerful.


      I will not bless what I do not understand. But I will no longer stand in its way.'
    isCloseup: 1
  - speaker: Wren
    text: 'That is a gate opening.'
    isCloseup: 0
  - speaker: Calden
    text: 'Here is the key to the garden gate. It should have been given long ago.'
    isCloseup: 0
