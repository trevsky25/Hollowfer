  m_Script: {fileID: 11500000, guid: 00c9c9bb92b3b44fb84ca335c48467d8, type: 3}
  m_Name: Dialogue_ApothecaryCase_BramRainShiver_Intake
  m_EditorClassIdentifier: Assembly-CSharp::Hollowfen.Dialogue.DialogueData
  _id: apothecary_case_bram_rain_shiver_intake
  _lines:
  - speaker: Bram
    text: It is a rain-shiver, nothing more. The sort a dry chair usually argues
      out of a man.
    isCloseup: 0
    voiceClip: {fileID: 8300000, guid: 1f35be353116a400d8dd0034d633e962, type: 3}
  - speaker: Wren
    text: Then we will listen before we argue with it.
    isCloseup: 0
    voiceClip: {fileID: 8300000, guid: 013192e4459764a2f9057076ab64aee2, type: 3}
  - speaker: Edda
    text: Good. Begin with what the weather changed, not what you expect to find.
    isCloseup: 0
    voiceClip: {fileID: 8300000, guid: b99294ec3af0147489623f1597c6cb52, type: 3}
