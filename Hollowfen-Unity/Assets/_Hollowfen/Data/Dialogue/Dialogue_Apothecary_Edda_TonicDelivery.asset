  m_Script: {fileID: 11500000, guid: 00c9c9bb92b3b44fb84ca335c48467d8, type: 3}
  m_Name: Dialogue_Apothecary_Edda_TonicDelivery
  m_EditorClassIdentifier: Assembly-CSharp::Hollowfen.Dialogue.DialogueData
  _id: apothecary.edda.tonic_delivery
  _lines:
  - speaker: Wren
    text: Sealed, dated, and entered twice. Once in the workshop ledger, once in
      mine.
    isCloseup: 0
    voiceClip: {fileID: 8300000, guid: aa10c8e1210064150874ded022d004eb, type: 3}
  - speaker: Edda
    text: Good. A frightened person reads badly. The label must do the remembering
      for them.
    isCloseup: 0
    voiceClip: {fileID: 8300000, guid: d3a673a002249488d972bc38cc0ca018, type: 3}
  - speaker: Edda
    text: This belongs to Hollowfen's shelf, not to rumor. That is how we keep care
      from becoming harm.
    isCloseup: 1
    voiceClip: {fileID: 8300000, guid: 59c3df78a329a4e25bc423969c8ea0a8, type: 3}
  - speaker: Wren
    text: Then the room is open.
    isCloseup: 0
    voiceClip: {fileID: 8300000, guid: e3e1d5ad3e2a64e9c8a0dbdd8f51b3e7, type: 3}
