  m_Script: {fileID: 11500000, guid: 00c9c9bb92b3b44fb84ca335c48467d8, type: 3}
  m_Name: Dialogue_Act1_CrookedPintle_BramKey
  m_EditorClassIdentifier: Assembly-CSharp::Hollowfen.Dialogue.DialogueData
  _id: act1.crooked_pintle.bram.key
  _lines:
  - speaker: Bram
    text: Marra's in back. She'll want to see you. Only she won't say so in a way
      you'll enjoy.
    isCloseup: 0
    voiceClip: {fileID: 8300000, guid: 0205ca836a2a74be8bb5e815e679093a, type: 3}
  - speaker: Wren
    text: That sounds like Marra.
    isCloseup: 0
    voiceClip: {fileID: 8300000, guid: a4a6c0753e3ce42bda362b407426e64b, type: 3}
  - speaker: Bram
    text: Your da left this with me when he took poorly.
    isCloseup: 0
    voiceClip: {fileID: 8300000, guid: a1f70177006474756af26489e7b4f477, type: 3}
  - speaker: Wren
    text: He knew?
    isCloseup: 0
    voiceClip: {fileID: 8300000, guid: 7f03a7b062f92485c9fb01872d12ef09, type: 3}
  - speaker: Bram
    text: 'He knew enough.


      You''ll find the mill in a state. I went by when
      I could.


      Wheel hasn''t turned since the Wend went and changed its mind
      about where it was going.'
    isCloseup: 0
    voiceClip: {fileID: 8300000, guid: d48801d786d1c4036956bb5d734cc23c, type: 3}
  - speaker: Wren
    text: Three winters ago?
    isCloseup: 0
    voiceClip: {fileID: 8300000, guid: 52d3a3fb5a8e9483ea412c86a3a986fe, type: 3}
  - speaker: Bram
    text: Aye.
    isCloseup: 0
    voiceClip: {fileID: 8300000, guid: 44f0fa6e5088549a0990f63976614cbd, type: 3}
  - speaker: Wren
    text: Father wrote that the lower fields flooded.
    isCloseup: 0
    voiceClip: {fileID: 8300000, guid: d062bdb9438bb44f0b04c07f9d59dc1c, type: 3}
  - speaker: Bram
    text: 'He would have written it tidy.


      He was a good man, your da.'
    isCloseup: 0
    voiceClip: {fileID: 8300000, guid: 6df499bb6ec5447748639d6ad55cc2b9, type: 3}
  - speaker: Wren
    text: That sounds like him.
    isCloseup: 0
    voiceClip: {fileID: 8300000, guid: 7ce014ba3a7454e2eb7618c78d7e40a8, type: 3}
  - speaker: Bram
    text: I'm sorry, Wren.
    isCloseup: 1
    voiceClip: {fileID: 8300000, guid: f58953799804e4edaab655b036949ca9, type: 3}
  - speaker: Wren
    text: So am I.
    isCloseup: 1
    voiceClip: {fileID: 8300000, guid: ecc8d334baaa342f9b19b8ae8f59bcf3, type: 3}
