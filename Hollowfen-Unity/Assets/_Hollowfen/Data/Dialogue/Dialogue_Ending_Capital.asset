  m_Script: {fileID: 11500000, guid: 00c9c9bb92b3b44fb84ca335c48467d8, type: 3}
  m_Name: Dialogue_Ending_Capital
  m_EditorClassIdentifier: Assembly-CSharp::Hollowfen.Dialogue.DialogueData
  _id: ending.capital.resolution
  _lines:
  - speaker: Theo
    text: Last chance to decide I am a terrible idea.
    isCloseup: 1
    voiceClip: {fileID: 8300000, guid: 0575cdc6f6c0e46d69692468b22c2baa, type: 3}
  - speaker: Wren
    text: You are a terrible idea.
    isCloseup: 1
    voiceClip: {fileID: 8300000, guid: feafcc2dd47ae4955b02a6c067d64688, type: 3}
  - speaker: Theo
    text: And?
    isCloseup: 1
    voiceClip: {fileID: 8300000, guid: d563e49b8b3d047e383857933c3626ff, type: 3}
  - speaker: Wren
    text: And the road is open.
    isCloseup: 1
    voiceClip: {fileID: 8300000, guid: 6c4dafae374fd46a6a50c202ce05f66e, type: 3}
  - speaker: Edda
    text: Will you write?
    isCloseup: 1
    voiceClip: {fileID: 8300000, guid: 73fe98a8fb7f54311ac641ff847496d9, type: 3}
  - speaker: Wren
    text: Yes. And if I stop, come be angry at me.
    isCloseup: 1
    voiceClip: {fileID: 8300000, guid: acbd40837cf634610b7b668a284586f3, type: 3}
