  m_Script: {fileID: 11500000, guid: 00c9c9bb92b3b44fb84ca335c48467d8, type: 3}
  m_Name: Dialogue_Act2_Voss_Demand
  m_EditorClassIdentifier: Assembly-CSharp::Hollowfen.Dialogue.DialogueData
  _id: act2.voss_first_visit.demand
  _lines:
  - speaker: Voss
    text: 'His Lordship requires twelve silver from this village.


      I am aware
      your fields have not yielded. I am not unsympathetic, but I am also not paid
      to be sympathetic.'
    isCloseup: 0
    voiceClip: {fileID: 8300000, guid: 4392058944df7460c9c37c551da11425, type: 3}
  - speaker: Wren
    text: Whose property is named?
    isCloseup: 0
    voiceClip: {fileID: 8300000, guid: 0fabcc835749c4d52abe886a6e3a6682, type: 3}
  - speaker: Voss
    text: The Wenmar cottage, if payment is not made by sundown.
    isCloseup: 1
    voiceClip: {fileID: 8300000, guid: 2db34eadfaf434a3c987df376857285c, type: 3}
  - speaker: Wren
    text: Then wait.
    isCloseup: 0
    voiceClip: {fileID: 8300000, guid: b58449ce30dc24a00b9ae4ab5373c507, type: 3}
  - speaker: Voss
    text: I was already doing so.
    isCloseup: 0
    voiceClip: {fileID: 8300000, guid: 4c275ba9073a94f33a23502138bc3d91, type: 3}
