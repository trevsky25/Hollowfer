  m_Name: Dialogue_Ending_LordlyPatronage
  m_EditorClassIdentifier: Assembly-CSharp::Hollowfen.Dialogue.DialogueData
  _id: ending.lordly_patronage.resolution
  _lines:
  - speaker: Aldric
    text: You are making the practical choice.
    isCloseup: 1
    voiceClip: {fileID: 8300000, guid: e4c85151789a34af0947a552cdb53088, type: 3}
  - speaker: Wren
    text: Do not make it smaller by praising it.
    isCloseup: 1
    voiceClip: {fileID: 8300000, guid: 4b43f66619e7c4ddf982e65dc403670c, type: 3}
  - speaker: Aldric
    text: Very well.
    isCloseup: 1
    voiceClip: {fileID: 8300000, guid: 5e5955e07372943368cd14b8eb5ef72e, type: 3}
  - speaker: Wren
    text: The village eats. That is the sentence I will use when I cannot sleep.
    isCloseup: 1
    voiceClip: {fileID: 8300000, guid: b3b888649938a4fbe9de3a411d02cab3, type: 3}
