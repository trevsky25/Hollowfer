  m_Script: {fileID: 11500000, guid: 00c9c9bb92b3b44fb84ca335c48467d8, type: 3}
  m_Name: Dialogue_Relationship_Joren_02
  m_EditorClassIdentifier: Assembly-CSharp::Hollowfen.Dialogue.DialogueData
  _id: relationship.joren.favor_02
  _lines:
  - speaker: Joren
    text: Your apothecary shelf leans. I made a bracket. You can hold it or criticize
      it, not both.
    isCloseup: 0
    voiceClip: {fileID: 8300000, guid: e0222265f2cc44009b364a2f267f5930, type: 3}
  - speaker: Wren
    text: I will hold it and criticize you quietly.
    isCloseup: 0
    voiceClip: {fileID: 8300000, guid: a9160920581254287b064245733d7f4f, type: 3}
  - speaker: Joren
    text: Good. Quiet work is the closest I come to company.
    isCloseup: 0
    voiceClip: {fileID: 8300000, guid: 8863c0c619b88410f98522a6929f5522, type: 3}
  - speaker: Wren
    text: Then I will be excellent company.
    isCloseup: 1
    voiceClip: {fileID: 8300000, guid: c20f71811b6394af0a327b0e6a9d2b68, type: 3}
