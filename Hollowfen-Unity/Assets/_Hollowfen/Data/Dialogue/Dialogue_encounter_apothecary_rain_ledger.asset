  m_Script: {fileID: 11500000, guid: 00c9c9bb92b3b44fb84ca335c48467d8, type: 3}
  m_Name: Dialogue_encounter_apothecary_rain_ledger
  m_EditorClassIdentifier: Assembly-CSharp::Hollowfen.Dialogue.DialogueData
  _id: encounter.apothecary_rain_ledger
  _lines:
  - speaker: Bram
    text: "Tobin marked rain days in the shelf ledger. Not the weather\u2014the people
      who came in pretending they were only wet."
    isCloseup: 0
    voiceClip: {fileID: 8300000, guid: b0abbb23f59cf4da28c499e3cc48c3b5, type: 3}
  - speaker: Edda
    text: Because cold pride sounds very much like silence.
    isCloseup: 0
    voiceClip: {fileID: 8300000, guid: 545c97e3d9cbd4c5cb9649d01bc45e4a, type: 3}
  - speaker: Wren
    text: 'Then we write both: coat soaked, breakfast missed, joke attempted.'
    isCloseup: 0
    voiceClip: {fileID: 8300000, guid: c2bedd754821e44a48b4f35718da3502, type: 3}
  - speaker: Bram
    text: Cruel accuracy.
    isCloseup: 0
    voiceClip: {fileID: 8300000, guid: f700569c3e4da4548b79fe71e197da64, type: 3}
  - speaker: Edda
    text: Useful accuracy. Keep that line, Wren.
    isCloseup: 1
    voiceClip: {fileID: 8300000, guid: a810f1f00e124409987ea0239c74ad5a, type: 3}
