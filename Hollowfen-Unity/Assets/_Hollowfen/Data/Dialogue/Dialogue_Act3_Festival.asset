  m_Script: {fileID: 11500000, guid: 00c9c9bb92b3b44fb84ca335c48467d8, type: 3}
  m_Name: Dialogue_Act3_Festival
  m_EditorClassIdentifier: Assembly-CSharp::Hollowfen.Dialogue.DialogueData
  _id: act3.festival
  _lines:
  - speaker: Marra
    text: 'Four dishes by sundown. If anyone calls it rustic, I will make them eat the garnish.'
    isCloseup: 1
  - speaker: Bram
    text: 'I remember where the lantern hooks go. Mostly.'
    isCloseup: 0
  - speaker: Pell
    text: 'This year''s page may need more ink.'
    isCloseup: 0
  - speaker: Wren
    text: 'The square filled before the lanterns were lit. Halfway through the evening I slipped behind the inn, where the gratitude was getting too thick to breathe.'
    isCloseup: 1
  - speaker: Edda
    text: 'You are hiding.'
    isCloseup: 0
  - speaker: Wren
    text: 'I am washing bowls privately.'
    isCloseup: 0
  - speaker: Edda
    text: 'That is hiding with dishes.'
    isCloseup: 0
  - speaker: Wren
    text: 'It was the first festival in three years. I let her be right about the bowls.'
    isCloseup: 1
