  m_Script: {fileID: 11500000, guid: 00c9c9bb92b3b44fb84ca335c48467d8, type: 3}
  m_Name: Dialogue_Act3_Festival
  m_EditorClassIdentifier: Assembly-CSharp::Hollowfen.Dialogue.DialogueData
  _id: act3.festival
  _lines:
  - speaker: Wren
    text: The square filled before the lanterns were lit. Halfway through the evening
      I slipped behind the inn, where the gratitude was getting too thick to breathe.
    isCloseup: 1
    voiceClip: {fileID: 8300000, guid: 5a3199c54d0cb4bc6b8c6ed222b520cf, type: 3}
  - speaker: Edda
    text: You are hiding.
    isCloseup: 0
    voiceClip: {fileID: 8300000, guid: e2e5e44e41c29441f919a7393ca69754, type: 3}
  - speaker: Wren
    text: I am washing bowls privately.
    isCloseup: 0
    voiceClip: {fileID: 8300000, guid: 2adc70af54ec8439e8447848a6e5e0ad, type: 3}
  - speaker: Edda
    text: That is hiding with dishes.
    isCloseup: 0
    voiceClip: {fileID: 8300000, guid: 57885b517b9b3478982502b4f11b9e42, type: 3}
  - speaker: Wren
    text: It was the first festival in three years. I let her be right about the
      bowls.
    isCloseup: 1
    voiceClip: {fileID: 8300000, guid: 49f5c1e926d4e488bae30295c86d1d24, type: 3}
