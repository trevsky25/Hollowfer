  m_Script: {fileID: 11500000, guid: 00c9c9bb92b3b44fb84ca335c48467d8, type: 3}
  m_Name: Dialogue_Act2_Theo_FirstSale
  m_EditorClassIdentifier: Assembly-CSharp::Hollowfen.Dialogue.DialogueData
  _id: act2.theo_wagon.first_sale
  _lines:
  - speaker: Theo
    text: Goldfoot. Where did you find these?
    isCloseup: 0
  - speaker: Wren
    text: Near trees.
    isCloseup: 0
  - speaker: Theo
    text: 'Cruel answer. I respect it.


      Anything else you find that looks like it shouldn''t be here, I want first
      refusal.'
    isCloseup: 1
  - speaker: Wren
    text: Why?
    isCloseup: 0
  - speaker: Theo
    text: Because I can sell it better than you can.
    isCloseup: 0
  - speaker: Wren
    text: Honest.
    isCloseup: 0
  - speaker: Theo
    text: 'When it saves time.


      That''s more than Bram could pay and less than the Capital would. I''m telling
      you both on purpose.'
    isCloseup: 0
