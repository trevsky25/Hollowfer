  m_EditorHideFlags: 0
  m_Script: {fileID: 11500000, guid: 00c9c9bb92b3b44fb84ca335c48467d8, type: 3}
  m_Name: Dialogue_Act2_Theo_FirstSale
  m_EditorClassIdentifier: Assembly-CSharp::Hollowfen.Dialogue.DialogueData
  _id: act2.theo_wagon.first_sale
  _lines:
  - speaker: Theo
    text: Goldfoot. Where did you find these?
    isCloseup: 0
    voiceClip: {fileID: 8300000, guid: cbd8c76b9ac4d4a8d8812cacfb1ef4d6, type: 3}
  - speaker: Wren
    text: Near trees.
    isCloseup: 0
    voiceClip: {fileID: 8300000, guid: 4a8a6ea2dda2f41d690e43c85834fe2b, type: 3}
  - speaker: Theo
    text: 'Cruel answer. I respect it.


      Anything else you find that looks
      like it shouldn''t be here, I want first refusal.'
    isCloseup: 1
    voiceClip: {fileID: 8300000, guid: 93d6ae549b9dd4c6ea295168c28b703f, type: 3}
  - speaker: Wren
    text: Why?
    isCloseup: 0
    voiceClip: {fileID: 8300000, guid: dc00184d59dae42d69ab2601f1d5ca3a, type: 3}
  - speaker: Theo
    text: Because I can sell it better than you can.
    isCloseup: 0
    voiceClip: {fileID: 8300000, guid: 7c4f6f8bb39914f6fb22aa351ff4631e, type: 3}
  - speaker: Wren
    text: Honest.
    isCloseup: 0
    voiceClip: {fileID: 8300000, guid: 512d11cf96e4a41d0905e0310693f44d, type: 3}
  - speaker: Theo
    text: 'When it saves time.


      That''s more than Bram could pay and less
      than the Capital would. I''m telling you both on purpose.'
    isCloseup: 0
    voiceClip: {fileID: 8300000, guid: 814cda8f705d74756bf6d95833887288, type: 3}
