  m_Name: Dialogue_Act3_Theo_Capital_Cost
  m_EditorClassIdentifier: Assembly-CSharp::Hollowfen.Dialogue.DialogueData
  _id: act3.theo.capital.cost
  _lines:
  - speaker: Theo
    text: Kitchen space. Proper signage. Staff within a year, if you do not insult
      everyone important.
    isCloseup: 0
    voiceClip: {fileID: 8300000, guid: 99625cac0cefa446780ccdf9c1c8bacb, type: 3}
  - speaker: Wren
    text: I would insult half.
    isCloseup: 0
    voiceClip: {fileID: 8300000, guid: 75283a9c3c889488abd122f58a4d7b14, type: 3}
  - speaker: Theo
    text: 'That is within tolerance.


      The cost is not coin. It is that you
      stop being the reason this place holds together.'
    isCloseup: 1
    voiceClip: {fileID: 8300000, guid: b41874b01ef9d45169efaaf756902717, type: 3}
