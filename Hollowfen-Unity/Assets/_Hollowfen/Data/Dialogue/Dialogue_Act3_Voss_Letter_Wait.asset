  _id: act3.voss.letter.wait
  _lines:
  - speaker: Wren
    text: I set it on the sill, wax up, and let it wait for evening. Some doors you
      choose the hour of.
    isCloseup: 1
    voiceClip: {fileID: 8300000, guid: 49404fd97b9e84adfb1539e8fb2c290a, type: 3}
  - speaker: Voss
    text: Sensible. It will say the same thing tonight.
    isCloseup: 0
    voiceClip: {fileID: 8300000, guid: f09cdb46d9f0b4315b5930c50f4adfbb, type: 3}
