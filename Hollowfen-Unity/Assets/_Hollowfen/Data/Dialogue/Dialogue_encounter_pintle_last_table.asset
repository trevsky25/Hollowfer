  m_Script: {fileID: 11500000, guid: 00c9c9bb92b3b44fb84ca335c48467d8, type: 3}
  m_Name: Dialogue_encounter_pintle_last_table
  m_EditorClassIdentifier: Assembly-CSharp::Hollowfen.Dialogue.DialogueData
  _id: encounter.pintle_last_table
  _lines:
  - speaker: Bram
    text: One bowl left. In the old days Tobin would arrive just late enough to claim
      it was an accident.
    isCloseup: 0
    voiceClip: {fileID: 8300000, guid: c025e01f51e14493da1dcd46908e42cb, type: 3}
  - speaker: Marra
    text: In the old days I always made one bowl too many.
    isCloseup: 0
    voiceClip: {fileID: 8300000, guid: 0c8b55ab34da5403194580d8a89acab8, type: 3}
  - speaker: Wren
    text: Then set three places tonight.
    isCloseup: 0
    voiceClip: {fileID: 8300000, guid: c8c0ff8dcaec248e6b3014c7d7e9b9c0, type: 3}
  - speaker: Bram
    text: For whom?
    isCloseup: 0
    voiceClip: {fileID: 8300000, guid: 8b728dade195b4d26a70c08b0233882f, type: 3}
  - speaker: Marra
    text: For whoever comes through the door needing not to explain themselves.
    isCloseup: 1
    voiceClip: {fileID: 8300000, guid: a211277548ca346d39b1ade8d8c09f72, type: 3}
