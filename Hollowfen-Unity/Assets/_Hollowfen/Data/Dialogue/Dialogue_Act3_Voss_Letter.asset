  m_Script: {fileID: 11500000, guid: 00c9c9bb92b3b44fb84ca335c48467d8, type: 3}
  m_Name: Dialogue_Act3_Voss_Letter
  m_EditorClassIdentifier: Assembly-CSharp::Hollowfen.Dialogue.DialogueData
  _id: act3.voss.letter
  _lines:
  - speaker: Voss
    text: 'I am not here to collect.'
    isCloseup: 1
  - speaker: Wren
    text: 'That is new.'
    isCloseup: 0
  - speaker: Voss
    text: 'Lord Aldric asked that I deliver this personally.


      Whatever it says, read it before the rumor reaches the inn.'
    isCloseup: 1
  - speaker: Wren
    text: 'Do you know what it says?'
    isCloseup: 0
  - speaker: Voss
    text: 'No.'
    isCloseup: 0
  - speaker: Wren
    text: 'Do you want to?'
    isCloseup: 0
  - speaker: Voss
    text: 'No.'
    isCloseup: 1
  - speaker: Wren
    text: 'The letter was folded thick and sealed with dark red wax. The mark pressed into it I had seen before — burned into the timber at the Wend''s old bend.'
    isCloseup: 1
  _unlockStoryCard: {fileID: 0}
  _completeQuest: {fileID: 0}
  _giveItemId: item.aldric_letter
