  _nextDialog: {fileID: 0}
  _choices:
  - text: 'Break the seal now.'
    next: {fileID: 11400000, guid: 53aa8713cb8b4124a070a3d643640add, type: 2}
    setsFlagId:
  - text: 'Set it aside until evening.'
    next: {fileID: 11400000, guid: 45dd66f4653144a4b418fc9e06edbfeb, type: 2}
