  m_EditorHideFlags: 0
  m_Script: {fileID: 11500000, guid: 00c9c9bb92b3b44fb84ca335c48467d8, type: 3}
  m_Name: Dialogue_Act3_Voss_Letter
  m_EditorClassIdentifier: Assembly-CSharp::Hollowfen.Dialogue.DialogueData
  _id: act3.voss.letter
  _lines:
  - speaker: Voss
    text: I am not here to collect.
    isCloseup: 1
    voiceClip: {fileID: 8300000, guid: 55288d9ddbd2848e2bc263c52948f956, type: 3}
  - speaker: Wren
    text: That is new.
    isCloseup: 0
    voiceClip: {fileID: 8300000, guid: 9d24745e732ae4d3fb626bea3a2212de, type: 3}
  - speaker: Voss
    text: 'Lord Aldric asked that I deliver this personally.


      Whatever it
      says, read it before the rumor reaches the inn.'
    isCloseup: 1
    voiceClip: {fileID: 8300000, guid: e5d9d0fc020934328a66ce8af93648b3, type: 3}
  - speaker: Wren
    text: Do you know what it says?
    isCloseup: 0
    voiceClip: {fileID: 8300000, guid: a88fa0d87f66b43f79f5ad4ae0615c65, type: 3}
  - speaker: Voss
    text: No.
    isCloseup: 0
    voiceClip: {fileID: 8300000, guid: 0cebc87ed1d254e1ba8f1daed50fc954, type: 3}
  - speaker: Wren
    text: Do you want to?
    isCloseup: 0
    voiceClip: {fileID: 8300000, guid: a008fd97c229942baa794eea3d06e197, type: 3}
  - speaker: Voss
    text: No.
    isCloseup: 1
    voiceClip: {fileID: 8300000, guid: d00da74b2362849a28662be84115660f, type: 3}
  - speaker: Wren
    text: "The letter was folded thick and sealed with dark red wax. The mark pressed
      into it I had seen before \u2014 burned into the timber at the Wend's old bend."
    isCloseup: 1
    voiceClip: {fileID: 8300000, guid: 3e533745488904930b34b3dbb9ae080e, type: 3}
