  m_Script: {fileID: 11500000, guid: 00c9c9bb92b3b44fb84ca335c48467d8, type: 3}
  m_Name: Dialogue_Relationship_Edda_01
  m_EditorClassIdentifier: Assembly-CSharp::Hollowfen.Dialogue.DialogueData
  _id: relationship.edda.favor_01
  _lines:
  - speaker: Edda
    text: Come check the care shelf with me. Preparing a tonic is half the work.
      Finding it where frightened hands expect it is the other half.
    isCloseup: 0
    voiceClip: {fileID: 8300000, guid: 844ebc2a9c53b494da26d90608dbf6ea, type: 3}
  - speaker: Wren
    text: Labels outward, oldest forward?
    isCloseup: 0
    voiceClip: {fileID: 8300000, guid: a452c704266c54dfc82144234798920e, type: 3}
  - speaker: Edda
    text: And every empty space explained. An unexplained empty shelf becomes a rumor
      by supper.
    isCloseup: 0
    voiceClip: {fileID: 8300000, guid: d05f088fbe8d741df9840340519151f9, type: 3}
  - speaker: Wren
    text: Then we leave no room for rumors.
    isCloseup: 1
    voiceClip: {fileID: 8300000, guid: a2dd6d09bd891476781583bdaf4be9eb, type: 3}
