  m_Name: Dialogue_Ending_FreeHollow
  m_EditorClassIdentifier: Assembly-CSharp::Hollowfen.Dialogue.DialogueData
  _id: ending.free_hollow.resolution
  _lines:
  - speaker: Wren
    text: No.
    isCloseup: 1
    voiceClip: {fileID: 8300000, guid: ea9935ac9735e42fcbdc46456551e3e5, type: 3}
  - speaker: Aldric
    text: That is rarely the first word in a negotiation.
    isCloseup: 1
    voiceClip: {fileID: 8300000, guid: 2ffe1d9b7243a45209cac34c1b846302, type: 3}
  - speaker: Wren
    text: It is the last word in this one.
    isCloseup: 1
    voiceClip: {fileID: 8300000, guid: 4605086c2f6034ec5a0b6766e63934a5, type: 3}
  - speaker: Aldric
    text: You may regret refusing protection.
    isCloseup: 1
    voiceClip: {fileID: 8300000, guid: 72b5c2ab8683a497fae791feabc3b767, type: 3}
  - speaker: Wren
    text: I expect to. That does not make it wrong.
    isCloseup: 1
    voiceClip: {fileID: 8300000, guid: 8d1ef596081fc438aa06cf526ab2da73, type: 3}
