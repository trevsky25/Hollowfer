  _id: apothecary.pell.ledger
  _lines:
  - speaker: Pell
    text: A workshop reopening counts as trade, care, inheritance, and fire inspection.
      I have given it four lines.
    isCloseup: 0
    voiceClip: {fileID: 8300000, guid: 77122b04f576942628789eebf6b70091, type: 3}
  - speaker: Wren
    text: Only four?
    isCloseup: 0
    voiceClip: {fileID: 8300000, guid: cbc3ff714f7c74b63a95eab497703de6, type: 3}
  - speaker: Pell
    text: Ink is not free. Apparently that is now your concern.
    isCloseup: 0
    voiceClip: {fileID: 8300000, guid: 147765286fb034c5b8a6bc6b94923512, type: 3}
