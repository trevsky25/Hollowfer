  m_EditorHideFlags: 0
  m_Script: {fileID: 11500000, guid: 00c9c9bb92b3b44fb84ca335c48467d8, type: 3}
  m_Name: Dialogue_Act2_Joren_Commission
  m_EditorClassIdentifier: Assembly-CSharp::Hollowfen.Dialogue.DialogueData
  _id: act2.jorens_forge.commission
  _lines:
  - speaker: Joren
    text: You want a foraging knife. From me.
    isCloseup: 0
    voiceClip: {fileID: 8300000, guid: efcfc7b63d49c41ff85b823f6492c65c, type: 3}
  - speaker: Wren
    text: If you still make knives.
    isCloseup: 0
    voiceClip: {fileID: 8300000, guid: c112a3ad5516341599a9f8a7acd521c1, type: 3}
  - speaker: Joren
    text: Careful.
    isCloseup: 0
    voiceClip: {fileID: 8300000, guid: db4eb1ea5c72e446ab248a9a922470d8, type: 3}
  - speaker: Wren
    text: Thin blade. Curved. Strong enough for brackets. Not pretty.
    isCloseup: 0
    voiceClip: {fileID: 8300000, guid: c8fdce070552442308ad3c83b555ee46, type: 3}
  - speaker: Joren
    text: Pretty costs extra and cuts worse.
    isCloseup: 0
    voiceClip: {fileID: 8300000, guid: c092b5bf2bac6404c899abb8e4ffa055, type: 3}
  - speaker: Wren
    text: There's coin on the bench. And father's old kitchen knife, for the shape
      of my hand.
    isCloseup: 0
    voiceClip: {fileID: 8300000, guid: 89d8e1f003cf049cdb200c0a20c19ee7, type: 3}
  - speaker: Joren
    text: Come back tomorrow. And don't tell anyone you commissioned it like charity.
    isCloseup: 1
    voiceClip: {fileID: 8300000, guid: bf063a7bc2d8742dc8692cc6c7ce7e1a, type: 3}
