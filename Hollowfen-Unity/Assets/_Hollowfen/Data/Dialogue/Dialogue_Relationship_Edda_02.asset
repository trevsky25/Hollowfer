  m_Name: Dialogue_Relationship_Edda_02
  m_EditorClassIdentifier: Assembly-CSharp::Hollowfen.Dialogue.DialogueData
  _id: relationship.edda.favor_02
  _lines:
  - speaker: Edda
    text: I have three cottage calls. Walk with me? Pell writes names, but sometimes
      names need faces beside them.
    isCloseup: 0
    voiceClip: {fileID: 8300000, guid: 0e3557ced47dd42d3b0d5206ad405294, type: 3}
  - speaker: Wren
    text: Tell me what to carry.
    isCloseup: 0
    voiceClip: {fileID: 8300000, guid: d3daaea0a062d44be9cc374c5e082fea, type: 3}
  - speaker: Edda
    text: Nothing. Today you listen. Care is not always an ingredient.
    isCloseup: 0
    voiceClip: {fileID: 8300000, guid: 315985512e1f04d959308455a6aa35b8, type: 3}
  - speaker: Wren
    text: I can learn that too.
    isCloseup: 1
    voiceClip: {fileID: 8300000, guid: 6c13283c5ad8345feb1d8feca77c170d, type: 3}
