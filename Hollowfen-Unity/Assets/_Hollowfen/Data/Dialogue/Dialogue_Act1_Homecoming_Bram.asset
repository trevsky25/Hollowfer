  m_Name: Dialogue_Act1_Homecoming_Bram
  m_EditorClassIdentifier: Assembly-CSharp::Hollowfen.Dialogue.DialogueData
  _id: act1.homecoming.bram.recognition
  _lines:
  - speaker: Bram
    text: Wren?
    isCloseup: 0
    voiceClip: {fileID: 8300000, guid: 865d20de8b8c44bb7a2d9674eeff9e62, type: 3}
  - speaker: Wren
    text: Evening, Bram.
    isCloseup: 0
    voiceClip: {fileID: 8300000, guid: 299772abe93e94934836a12d5b5febf0, type: 3}
  - speaker: Bram
    text: Lord help me. You've got your father's height.
    isCloseup: 0
    voiceClip: {fileID: 8300000, guid: 06ecf5c63fd604643951c19b2790e554, type: 3}
  - speaker: Wren
    text: I came as soon as I could.
    isCloseup: 1
    voiceClip: {fileID: 8300000, guid: 0730fc564d858419cb8f243981abcbd0, type: 3}
  - speaker: Bram
    text: 'Aye. I know.


      I''ve got the key inside.'
    isCloseup: 0
    voiceClip: {fileID: 8300000, guid: 42952d01c9d0b4b48890718f22f74fcd, type: 3}
