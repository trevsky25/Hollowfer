  _id: act3.festival.gathering
  _lines:
  - speaker: Marra
    text: Four dishes by sundown. If anyone calls it rustic, I will make them eat
      the garnish.
    isCloseup: 1
    voiceClip: {fileID: 8300000, guid: a4a3b33aa70974210bc7ce711d84423c, type: 3}
  - speaker: Bram
    text: I remember where the lantern hooks go. Mostly.
    isCloseup: 0
    voiceClip: {fileID: 8300000, guid: b0620b20fe2c0435eaa6864603b4a926, type: 3}
  - speaker: Pell
    text: This year's page may need more ink.
    isCloseup: 0
    voiceClip: {fileID: 8300000, guid: 8c5cbc02f4c354b859adf43a4077c3f5, type: 3}
