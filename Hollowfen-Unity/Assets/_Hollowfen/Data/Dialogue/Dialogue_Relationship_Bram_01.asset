  m_Script: {fileID: 11500000, guid: 00c9c9bb92b3b44fb84ca335c48467d8, type: 3}
  m_Name: Dialogue_Relationship_Bram_01
  m_EditorClassIdentifier: Assembly-CSharp::Hollowfen.Dialogue.DialogueData
  _id: relationship.bram.favor_01
  _lines:
  - speaker: Bram
    text: The Pintle has tables again. One of them still rocks, which is how I know
      it is truly ours.
    isCloseup: 0
    voiceClip: {fileID: 8300000, guid: 068d48a08179741e9a5e33f7f15ad21a, type: 3}
  - speaker: Wren
    text: I can hold the bowl and the table at once.
    isCloseup: 0
    voiceClip: {fileID: 8300000, guid: 2593eb8dd6ebd45b6b5df95517e5ee8f, type: 3}
  - speaker: Bram
    text: You can sit. Marra left stew, and I have spent three years saving a story
      your father would hate me for telling.
    isCloseup: 0
    voiceClip: {fileID: 8300000, guid: 351fa6056966e4b9693b484234b07837, type: 3}
  - speaker: Wren
    text: Then start before the stew gets cold.
    isCloseup: 1
    voiceClip: {fileID: 8300000, guid: 4956c0e03fc904834a204aac2f41baed, type: 3}
