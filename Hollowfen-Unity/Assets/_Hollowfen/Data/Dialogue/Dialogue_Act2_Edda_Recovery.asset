    text: He ate today. The whole bowl.
    isCloseup: 1
    voiceClip: {fileID: 8300000, guid: 05d5502b7c45c49b58fa711332073941, type: 3}
  - speaker: Wren
    text: Good.
    isCloseup: 0
    voiceClip: {fileID: 8300000, guid: 923471927d6ab4b03817903280d99036, type: 3}
  - speaker: Edda
    text: That is not a big enough word.
    isCloseup: 1
    voiceClip: {fileID: 8300000, guid: dec588b3609034ee6aa10f10047c3e0e, type: 3}
  - speaker: Wren
    text: No.
    isCloseup: 0
    voiceClip: {fileID: 8300000, guid: 3c638739987e242c181b4d8d5130eeb6, type: 3}
