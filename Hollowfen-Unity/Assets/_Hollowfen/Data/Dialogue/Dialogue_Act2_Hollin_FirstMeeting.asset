  m_Script: {fileID: 11500000, guid: 00c9c9bb92b3b44fb84ca335c48467d8, type: 3}
  m_Name: Dialogue_Act2_Hollin_FirstMeeting
  m_EditorClassIdentifier: Assembly-CSharp::Hollowfen.Dialogue.DialogueData
  _id: act2.hollin.first_meeting
  _lines:
  - speaker: Hollin
    text: 'I asked at three villages before someone said your name.'
    isCloseup: 1
  - speaker: Wren
    text: 'Are you buying?'
    isCloseup: 0
  - speaker: Hollin
    text: 'No.'
    isCloseup: 0
  - speaker: Wren
    text: 'Selling?'
    isCloseup: 0
  - speaker: Hollin
    text: 'No.


      I am walking. And looking for a place my grandmother used to name when she thought no one was listening.'
    isCloseup: 0
  - speaker: Wren
    text: 'What place?'
    isCloseup: 0
  - speaker: Hollin
    text: 'Not yet.'
    isCloseup: 1
