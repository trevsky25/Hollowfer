  m_Script: {fileID: 11500000, guid: 00c9c9bb92b3b44fb84ca335c48467d8, type: 3}
  m_Name: Dialogue_Act2_Hollin_FirstMeeting
  m_EditorClassIdentifier: Assembly-CSharp::Hollowfen.Dialogue.DialogueData
  _id: act2.hollin.first_meeting
  _lines:
  - speaker: Hollin
    text: I asked at three villages before someone said your name.
    isCloseup: 1
    voiceClip: {fileID: 8300000, guid: 3ba6bcc49a1ca4549a2523a1f2965a40, type: 3}
  - speaker: Wren
    text: Are you buying?
    isCloseup: 0
    voiceClip: {fileID: 8300000, guid: bb36e3555fff6466ebf5d8a592c11db8, type: 3}
  - speaker: Hollin
    text: No.
    isCloseup: 0
    voiceClip: {fileID: 8300000, guid: e79a14437d6014372b1cb0e3b99ef50d, type: 3}
  - speaker: Wren
    text: Selling?
    isCloseup: 0
    voiceClip: {fileID: 8300000, guid: c0a0f9ec1dfec4227994f8b4602d1354, type: 3}
  - speaker: Hollin
    text: 'No.


      I am walking. And looking for a place my grandmother used
      to name when she thought no one was listening.'
    isCloseup: 0
    voiceClip: {fileID: 8300000, guid: edc15b0ef0c56462cb9801e5c451d09c, type: 3}
  - speaker: Wren
    text: What place?
    isCloseup: 0
    voiceClip: {fileID: 8300000, guid: 0a1105c1a9e4a48ac978a1a3d535a8ae, type: 3}
  - speaker: Hollin
    text: Not yet.
    isCloseup: 1
    voiceClip: {fileID: 8300000, guid: 429b38a3bb1844fb09cfb60e27d9d6ba, type: 3}
