  m_Name: Dialogue_Relationship_Almy_01
  m_EditorClassIdentifier: Assembly-CSharp::Hollowfen.Dialogue.DialogueData
  _id: relationship.almy.favor_01
  _lines:
  - speaker: Almy
    text: Walk the new beds with me. A garden tells on its keeper before the keeper
      knows to confess.
    isCloseup: 0
    voiceClip: {fileID: 8300000, guid: 8c4d672c8d36046229e5a8017a8ff7fd, type: 3}
  - speaker: Wren
    text: What are mine saying?
    isCloseup: 0
    voiceClip: {fileID: 8300000, guid: 256b2cdc18a084422a2f056eef396c26, type: 3}
  - speaker: Almy
    text: That you water like someone apologizing. Roots prefer confidence.
    isCloseup: 0
    voiceClip: {fileID: 8300000, guid: 3e086132e255841d5b63845867adff4d, type: 3}
  - speaker: Wren
    text: Show me where to stand, then.
    isCloseup: 1
    voiceClip: {fileID: 8300000, guid: e787b6041874e455d9d24f78959648d1, type: 3}
