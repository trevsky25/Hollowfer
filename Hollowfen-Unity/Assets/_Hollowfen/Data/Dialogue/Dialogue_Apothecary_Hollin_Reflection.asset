  m_Script: {fileID: 11500000, guid: 00c9c9bb92b3b44fb84ca335c48467d8, type: 3}
  m_Name: Dialogue_Apothecary_Hollin_Reflection
  m_EditorClassIdentifier: Assembly-CSharp::Hollowfen.Dialogue.DialogueData
  _id: apothecary.hollin.reflection
  _lines:
  - speaker: Hollin
    text: Sable kept her knowledge behind a door. Your father kept his inside a book.
    isCloseup: 0
    voiceClip: {fileID: 8300000, guid: 25c11332b5a5440158cf9d108aba8810, type: 3}
  - speaker: Wren
    text: And I put mine on labels.
    isCloseup: 0
    voiceClip: {fileID: 8300000, guid: 38862045ce38a4f959bc2aa1a71e9874, type: 3}
  - speaker: Hollin
    text: Yes. A village can argue with a label. A secret only waits to be lost.
    isCloseup: 1
    voiceClip: {fileID: 8300000, guid: 4b1d2864db34048d1beab1c4ca30f68a, type: 3}
