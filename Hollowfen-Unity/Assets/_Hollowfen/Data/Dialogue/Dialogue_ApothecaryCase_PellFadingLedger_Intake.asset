  m_Script: {fileID: 11500000, guid: 00c9c9bb92b3b44fb84ca335c48467d8, type: 3}
  m_Name: Dialogue_ApothecaryCase_PellFadingLedger_Intake
  m_EditorClassIdentifier: Assembly-CSharp::Hollowfen.Dialogue.DialogueData
  _id: apothecary_case_pell_fading_ledger_intake
  _lines:
  - speaker: Pell
    text: The north-lane figures blur every evening. I would prefer an answer that
      does not begin with my age.
    isCloseup: 0
    voiceClip: {fileID: 8300000, guid: 24a3e7511a4aa4cb6b3a1e498eec372a, type: 3}
  - speaker: Wren
    text: Then I will examine the ledger as carefully as its keeper.
    isCloseup: 0
    voiceClip: {fileID: 8300000, guid: 9cfd8a23d068c4590b94b541cac2d1d7, type: 3}
  - speaker: Edda
    text: A case is sometimes the person. Sometimes it is the thing they have trusted
      too long.
    isCloseup: 0
    voiceClip: {fileID: 8300000, guid: af41924490a874859a11def289b2d418, type: 3}
