  m_Script: {fileID: 11500000, guid: 00c9c9bb92b3b44fb84ca335c48467d8, type: 3}
  m_Name: Dialogue_Act1_MarraKitchen_FirstBasket
  m_EditorClassIdentifier: Assembly-CSharp::Hollowfen.Dialogue.DialogueData
  _id: act1.marra_kitchen.first_basket
  _lines:
  - speaker: Bram
    text: 'Field Caps. Wood Ear.


      Pinecrest.


      Marra.'
    isCloseup: 0
  - speaker: Wren
    text: Are they worth anything?
    isCloseup: 0
  - speaker: Marra
    text: What?
    isCloseup: 0
  - speaker: Bram
    text: Come here.
    isCloseup: 0
  - speaker: Marra
    text: If the roof's fallen in, stand somewhere else.
    isCloseup: 0
  - speaker: Bram
    text: Marra.
    isCloseup: 0
  - speaker: Marra
    text: Where did you get those?
    isCloseup: 0
  - speaker: Wren
    text: Edge Woods.
    isCloseup: 0
  - speaker: Marra
    text: You picked them yourself?
    isCloseup: 0
  - speaker: Wren
    text: I checked them against Father's journal. Mostly.
    isCloseup: 0
  - speaker: Marra
    text: Goldfoots.
    isCloseup: 1
  - speaker: Bram
    text: In this kitchen. After twenty years.
    isCloseup: 0
  - speaker: Marra
    text: Cold water.
    isCloseup: 0
  - speaker: Wren
    text: What?
    isCloseup: 0
  - speaker: Marra
    text: 'You wash these in cold water. Not hot. Hot bruises them and makes liars
      of the texture.


      I''ll tell you twice and not three times.'
    isCloseup: 0
  _unlockStoryCard: {fileID: 0}
  _completeQuest: {fileID: 0}
  _giveItemId:
  _grantCoinsCopper: 0
  _sellsForageBasket: 0
  _nextDialog: {fileID: 11400000, guid: ec2017c785124fd6a5003b6dedf73e29, type: 2}
