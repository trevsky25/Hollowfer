  m_Script: {fileID: 11500000, guid: 00c9c9bb92b3b44fb84ca335c48467d8, type: 3}
  m_Name: Dialogue_Apothecary_Bram_TobinMemory
  m_EditorClassIdentifier: Assembly-CSharp::Hollowfen.Dialogue.DialogueData
  _id: apothecary.bram.tobin_memory
  _lines:
  - speaker: Bram
    text: Tobin used to come down after midnight with ink on both cuffs and ask whether
      the rain had changed its mind.
    isCloseup: 0
    voiceClip: {fileID: 8300000, guid: 972d78ea676894c78b8f184dbf59ead5, type: 3}
  - speaker: Wren
    text: Did it?
    isCloseup: 0
    voiceClip: {fileID: 8300000, guid: 137b794e1c1f5424cb83a1dee750e12e, type: 3}
  - speaker: Bram
    text: Never. But he kept better notes than the weather did.
    isCloseup: 0
    voiceClip: {fileID: 8300000, guid: ecf2b46702b20445c8c5e8b876830898, type: 3}
