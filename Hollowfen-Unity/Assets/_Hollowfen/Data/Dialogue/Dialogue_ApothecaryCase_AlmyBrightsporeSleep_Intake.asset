  m_Name: Dialogue_ApothecaryCase_AlmyBrightsporeSleep_Intake
  m_EditorClassIdentifier: Assembly-CSharp::Hollowfen.Dialogue.DialogueData
  _id: apothecary_case_almy_brightspore_sleep_intake
  _lines:
  - speaker: Almy
    text: The Brightspore beds keep following me into sleep. I wake as though the
      chapel lamps are still burning.
    isCloseup: 0
    voiceClip: {fileID: 8300000, guid: 3ce7a77b20bcf4054af9f74f363e2a4e, type: 3}
  - speaker: Wren
    text: How long were you among the fruiting trays yesterday?
    isCloseup: 0
    voiceClip: {fileID: 8300000, guid: 2260b40b637c741b39c4699a4c34f607, type: 3}
  - speaker: Edda
    text: Treat the pattern with respect. Familiar work can still change its worker.
    isCloseup: 0
    voiceClip: {fileID: 8300000, guid: 4a5b244fe1cb5400ea04410ec7bc8d2c, type: 3}
