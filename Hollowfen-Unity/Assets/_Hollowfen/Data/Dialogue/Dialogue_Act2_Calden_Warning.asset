  m_Script: {fileID: 11500000, guid: 00c9c9bb92b3b44fb84ca335c48467d8, type: 3}
  m_Name: Dialogue_Act2_Calden_Warning
  m_EditorClassIdentifier: Assembly-CSharp::Hollowfen.Dialogue.DialogueData
  _id: act2.calden.warning
  _lines:
  - speaker: Calden
    text: 'I knew your father. I baptized you.


      So I will say this once and
      kindly: leave the deep wood alone.'
    isCloseup: 1
    voiceClip: {fileID: 8300000, guid: 8857c5ae26e5e4c93bb746ac3a4f3259, type: 3}
  - speaker: Wren
    text: The Edge Woods fed your village this month.
    isCloseup: 0
    voiceClip: {fileID: 8300000, guid: 0e82f1b151d9d4b3f9717b0675677b2c, type: 3}
  - speaker: Calden
    text: The edge of a thing is not the thing.
    isCloseup: 0
    voiceClip: {fileID: 8300000, guid: 4d76d9316bc714d4c87251bdcc59cdb1, type: 3}
  - speaker: Wren
    text: What are you afraid of?
    isCloseup: 0
    voiceClip: {fileID: 8300000, guid: 39ca3cc565d8c4843a69cdf9cc39a055, type: 3}
  - speaker: Calden
    text: Being late to wisdom. Being early to harm.
    isCloseup: 1
    voiceClip: {fileID: 8300000, guid: f65d4b1bc7e9849e0aee62003c741639, type: 3}
