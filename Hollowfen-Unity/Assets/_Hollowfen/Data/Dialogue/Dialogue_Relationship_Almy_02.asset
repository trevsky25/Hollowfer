  m_Script: {fileID: 11500000, guid: 00c9c9bb92b3b44fb84ca335c48467d8, type: 3}
  m_Name: Dialogue_Relationship_Almy_02
  m_EditorClassIdentifier: Assembly-CSharp::Hollowfen.Dialogue.DialogueData
  _id: relationship.almy.favor_02
  _lines:
  - speaker: Almy
    text: I found one of Sable's notes pressed beneath the seed ledger. I nearly
      kept it to myself.
    isCloseup: 0
    voiceClip: {fileID: 8300000, guid: f8980fb2b8df74b3899805f62917b6b1, type: 3}
  - speaker: Wren
    text: But you brought it.
    isCloseup: 0
    voiceClip: {fileID: 8300000, guid: 46792e120a2f44c8a9863e50db2a19da, type: 3}
  - speaker: Almy
    text: Edda reminded me that a guarded truth can still become a lost truth. Your
      workshop has changed more than its shelves.
    isCloseup: 0
    voiceClip: {fileID: 8300000, guid: b257e1dced66544e9ac48910f632a859, type: 3}
  - speaker: Wren
    text: We will copy it twice. Then we will argue with it.
    isCloseup: 1
    voiceClip: {fileID: 8300000, guid: edb7a847ff2d24fafbe046b2024ed958, type: 3}
