  m_Script: {fileID: 11500000, guid: 00c9c9bb92b3b44fb84ca335c48467d8, type: 3}
  m_Name: Dialogue_Act4_Consult_Bram
  m_EditorClassIdentifier: Assembly-CSharp::Hollowfen.Dialogue.DialogueData
  _id: act4.consult.bram
  _lines:
  - speaker: Wren
    text: 'Bram. Lord Aldric has made an offer. I would hear what you think of it.'
    isCloseup: 0
  - speaker: Bram
    text: 'A lord''s banner over the door would bring the road back. Traders, coin, a full common room by winter.'
    isCloseup: 1
  - speaker: Bram
    text: 'But a road that comes because a lord allows it can be closed the same way. I have poured for men who owned the roof they drank under. They did not laugh the same.'
    isCloseup: 1
