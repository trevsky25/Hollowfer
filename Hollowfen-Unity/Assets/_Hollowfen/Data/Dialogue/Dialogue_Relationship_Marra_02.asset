  m_Script: {fileID: 11500000, guid: 00c9c9bb92b3b44fb84ca335c48467d8, type: 3}
  m_Name: Dialogue_Relationship_Marra_02
  m_EditorClassIdentifier: Assembly-CSharp::Hollowfen.Dialogue.DialogueData
  _id: relationship.marra.favor_02
  _lines:
  - speaker: Marra
    text: 'Festivals end in three things: wax, dishes, and people disappearing before
      either is cleared.'
    isCloseup: 0
    voiceClip: {fileID: 8300000, guid: 08f1296c930734af7a91498c01f9b9a4, type: 3}
  - speaker: Wren
    text: I brought sleeves.
    isCloseup: 0
    voiceClip: {fileID: 8300000, guid: b8119efdafd9b4909a5f1f15522740b9, type: 3}
  - speaker: Marra
    text: Edda brought salve. Bram brought opinions. You may stay.
    isCloseup: 0
    voiceClip: {fileID: 8300000, guid: 1c932c1ec5f9c41ddb404e7da820ec96, type: 3}
  - speaker: Wren
    text: That is nearly affectionate.
    isCloseup: 0
    voiceClip: {fileID: 8300000, guid: 7cc83770af78740f8a9475231eca9a02, type: 3}
  - speaker: Marra
    text: Do not make me withdraw it.
    isCloseup: 1
    voiceClip: {fileID: 8300000, guid: d08639eb65e9e475785b6d62d14ef154, type: 3}
