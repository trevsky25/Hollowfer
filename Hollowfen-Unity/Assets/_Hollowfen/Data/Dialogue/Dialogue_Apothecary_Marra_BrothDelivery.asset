  _id: apothecary.marra.broth_delivery
  _lines:
  - speaker: Wren
    text: The first covered jar from the restored bench.
    isCloseup: 0
    voiceClip: {fileID: 8300000, guid: 5ebfb384e9ad24319a4db02972f1dbec, type: 3}
  - speaker: Marra
    text: Label straight. Lid sound. Smells like Goldfoot without shouting about
      it.
    isCloseup: 0
    voiceClip: {fileID: 8300000, guid: eb8a6dc1c80544632919145b195df053, type: 3}
  - speaker: Marra
    text: Tobin kept secrets. You are keeping stock. That may be the more useful
      inheritance.
    isCloseup: 1
    voiceClip: {fileID: 8300000, guid: 82ce390f2999d4e61af6fae8c879d7ae, type: 3}
