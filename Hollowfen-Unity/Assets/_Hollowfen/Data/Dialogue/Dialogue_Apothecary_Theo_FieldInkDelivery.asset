  m_Script: {fileID: 11500000, guid: 00c9c9bb92b3b44fb84ca335c48467d8, type: 3}
  m_Name: Dialogue_Apothecary_Theo_FieldInkDelivery
  m_EditorClassIdentifier: Assembly-CSharp::Hollowfen.Dialogue.DialogueData
  _id: apothecary.theo.field_ink_delivery
  _lines:
  - speaker: Wren
    text: One stoppered inkwell. It dried dark enough to survive my thumb.
    isCloseup: 0
    voiceClip: {fileID: 8300000, guid: b0fd2d22562724e8aa36545ae7887efb, type: 3}
  - speaker: Theo
    text: And the road, I hope. Your father sold me notes once. The rain bought most
      of them before I reached the ridge.
    isCloseup: 0
    voiceClip: {fileID: 8300000, guid: 8cb14db07696b47dbadb8e59a1116a56, type: 3}
  - speaker: Theo
    text: This is better work, Wren. Not because it is grand. Because it arrives
      readable.
    isCloseup: 1
    voiceClip: {fileID: 8300000, guid: 372f6157821c642b8921708572a583ef, type: 3}
