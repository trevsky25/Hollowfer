  m_Name: Dialogue_encounter_forge_ledger
  m_EditorClassIdentifier: Assembly-CSharp::Hollowfen.Dialogue.DialogueData
  _id: encounter.forge_ledger
  _lines:
  - speaker: Pell
    text: You have written 'hinges' where the ledger asks for public benefit.
    isCloseup: 0
    voiceClip: {fileID: 8300000, guid: 17d2cf1842e3a459a920769a9f072a56, type: 3}
  - speaker: Joren
    text: Doors that open are a public benefit.
    isCloseup: 0
    voiceClip: {fileID: 8300000, guid: 655e8e0f38f274001a71f07de9486375, type: 3}
  - speaker: Wren
    text: Write 'doors opened,' then keep the hinges in the margin.
    isCloseup: 0
    voiceClip: {fileID: 8300000, guid: ad77f0988679a4b5197af02039063b6d, type: 3}
  - speaker: Pell
    text: Imprecise, but defensible.
    isCloseup: 0
    voiceClip: {fileID: 8300000, guid: 237e85e788b0a4eb69be42dbcd095c04, type: 3}
  - speaker: Joren
    text: That is the warmest thing he has ever said about my work.
    isCloseup: 1
    voiceClip: {fileID: 8300000, guid: db43065188fee4b6fae8bfec423f5e20, type: 3}
