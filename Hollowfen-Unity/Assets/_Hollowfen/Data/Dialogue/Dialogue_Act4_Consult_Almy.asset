  m_Script: {fileID: 11500000, guid: 00c9c9bb92b3b44fb84ca335c48467d8, type: 3}
  m_Name: Dialogue_Act4_Consult_Almy
  m_EditorClassIdentifier: Assembly-CSharp::Hollowfen.Dialogue.DialogueData
  _id: act4.consult.almy
  _lines:
  - speaker: Wren
    text: "Sister. He wants the records, the routes, the preparations \u2014 held
      in trust."
    isCloseup: 0
    voiceClip: {fileID: 8300000, guid: 0c73b184c6a6f4601bf65d4e546bcf91, type: 3}
  - speaker: Almy
    text: Held in trust. I have read that phrase in older ledgers than his.
    isCloseup: 1
    voiceClip: {fileID: 8300000, guid: 3e1c81c5b48ff4919a2fb2e851f48459, type: 3}
  - speaker: Almy
    text: What the garden knows, the garden should keep. Give a lord the records
      and you have given him the harvest, the cure, and the next hungry winter's
      mercy. I would not sign.
    isCloseup: 1
    voiceClip: {fileID: 8300000, guid: 38a5812c306134bd480a9b8a13935ce8, type: 3}
