  m_Script: {fileID: 11500000, guid: 00c9c9bb92b3b44fb84ca335c48467d8, type: 3}
  m_Name: Dialogue_Act4_Consult_Almy
  m_EditorClassIdentifier: Assembly-CSharp::Hollowfen.Dialogue.DialogueData
  _id: act4.consult.almy
  _lines:
  - speaker: Wren
    text: 'Sister. He wants the records, the routes, the preparations — held in trust.'
    isCloseup: 0
  - speaker: Almy
    text: 'Held in trust. I have read that phrase in older ledgers than his.'
    isCloseup: 1
  - speaker: Almy
    text: 'What the garden knows, the garden should keep. Give a lord the records and you have given him the harvest, the cure, and the next hungry winter''s mercy. I would not sign.'
    isCloseup: 1
