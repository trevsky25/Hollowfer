  m_Script: {fileID: 11500000, guid: 00c9c9bb92b3b44fb84ca335c48467d8, type: 3}
  m_Name: Dialogue_Relationship_Bram_02
  m_EditorClassIdentifier: Assembly-CSharp::Hollowfen.Dialogue.DialogueData
  _id: relationship.bram.favor_02
  _lines:
  - speaker: Bram
    text: Walk the shutters with me? After a full room, the quiet arrives too quickly.
    isCloseup: 0
    voiceClip: {fileID: 8300000, guid: d540dd27221674e5abb97895607a2a75, type: 3}
  - speaker: Wren
    text: Which lantern goes out last?
    isCloseup: 0
    voiceClip: {fileID: 8300000, guid: 9f48ec59bd8df4e19b41a5f81d869c6f, type: 3}
  - speaker: Bram
    text: The one over Tobin's corner. Habit is a poor memorial, but it kept a place
      for you.
    isCloseup: 0
    voiceClip: {fileID: 8300000, guid: 78b5bd1dfecce4e0e8e8582e472cdf59, type: 3}
  - speaker: Wren
    text: Tonight we can call it something better than habit.
    isCloseup: 1
    voiceClip: {fileID: 8300000, guid: 2b56581b9f3ef4e22badbc3c846c8381, type: 3}
