  m_Script: {fileID: 11500000, guid: 00c9c9bb92b3b44fb84ca335c48467d8, type: 3}
  m_Name: Dialogue_Act4_Consult_Hollin
  m_EditorClassIdentifier: Assembly-CSharp::Hollowfen.Dialogue.DialogueData
  _id: act4.consult.hollin
  _lines:
  - speaker: Wren
    text: You have read Sable's book. Tell me what you make of a lord who wants to
      hold it in trust.
    isCloseup: 0
    voiceClip: {fileID: 8300000, guid: 0ee4d30614ad04fe49bb5c84b4713e85, type: 3}
  - speaker: Hollin
    text: Sable's book is not his to hold. Neither is your grandmother's.
    isCloseup: 1
    voiceClip: {fileID: 8300000, guid: f0d70ed6978fb485184832fa88fd3041, type: 3}
  - speaker: Hollin
    text: "Some things you do not sign away, Wren \u2014 not for a good road, not
      for a soft year. The Hollow was not saved by a lord. It was saved by you not
      asking one."
    isCloseup: 1
    voiceClip: {fileID: 8300000, guid: a34966a03621c43938927d54210c5bdc, type: 3}
