  _choices:
  - text: What would that cost me?
    next: {fileID: 11400000, guid: cd213d2631374534adaee11f24cbfc37, type: 2}
    setsFlagId: 
    ending: {fileID: 0}
  - text: "And Hollowfen \u2014 what happens to it?"
    next: {fileID: 11400000, guid: c298b380599149049a3a44cd50d6945f, type: 2}
    setsFlagId: 
    ending: {fileID: 0}
  - text: When would this be?
    next: {fileID: 11400000, guid: f7625a6294bf435b8bcd623ed94c4057, type: 2}
    setsFlagId: 
    ending: {fileID: 0}
  - text: I need to think on it.
    next: {fileID: 11400000, guid: 65a41759aabd4162a10a1fbd17a3247f, type: 2}
    setsFlagId: 
    ending: {fileID: 0}
