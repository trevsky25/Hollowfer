  m_EditorHideFlags: 0
  m_Script: {fileID: 11500000, guid: 00c9c9bb92b3b44fb84ca335c48467d8, type: 3}
  m_Name: Dialogue_Act3_Theo_Capital
  m_EditorClassIdentifier: Assembly-CSharp::Hollowfen.Dialogue.DialogueData
  _id: act3.theo.capital
  _lines:
  - speaker: Theo
    text: I have a buyer in the Capital. Not a buyer, really. A backer.
    isCloseup: 1
    voiceClip: {fileID: 8300000, guid: 8e5a7a8c6d26d44a9a223522cd0fa3d8, type: 3}
  - speaker: Wren
    text: For mushrooms?
    isCloseup: 0
    voiceClip: {fileID: 8300000, guid: 48c9fb7d24e1c45169812708ab24554c, type: 3}
  - speaker: Theo
    text: For you.
    isCloseup: 1
    voiceClip: {fileID: 8300000, guid: 6358659f7a6a04aa1882a4523f53cf2a, type: 3}
  - speaker: Theo
    text: It would cost Hollowfen you.
    isCloseup: 1
    voiceClip: {fileID: 8300000, guid: 50106f2f291df4907af2a2226c9a1df5, type: 3}
  - speaker: Wren
    text: You think I do not know that?
    isCloseup: 0
    voiceClip: {fileID: 8300000, guid: 300459009962343109166984f3061da4, type: 3}
  - speaker: Theo
    text: I think you know it better than I do. I am saying it so the offer is clean.
    isCloseup: 1
    voiceClip: {fileID: 8300000, guid: 468fc469aa0994b548a163d4342768bd, type: 3}
