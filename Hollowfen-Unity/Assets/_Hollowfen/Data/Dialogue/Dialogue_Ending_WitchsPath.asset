  m_Name: Dialogue_Ending_WitchsPath
  m_EditorClassIdentifier: Assembly-CSharp::Hollowfen.Dialogue.DialogueData
  _id: ending.witch_path.resolution
  _lines:
  - speaker: Hollin
    text: What do we call this?
    isCloseup: 1
    voiceClip: {fileID: 8300000, guid: eab5375a3908e493aa548faea40879d7, type: 3}
  - speaker: Wren
    text: Work.
    isCloseup: 1
    voiceClip: {fileID: 8300000, guid: 73b1990c05fdb42d8981945723782af5, type: 3}
  - speaker: Hollin
    text: People prefer grander names.
    isCloseup: 1
    voiceClip: {fileID: 8300000, guid: 752b123ff80414c769496aa7e225b9ae, type: 3}
  - speaker: Wren
    text: Then people can be disappointed.
    isCloseup: 1
    voiceClip: {fileID: 8300000, guid: 4a9da208837524eb99caa5fd2a76cdd9, type: 3}
  - speaker: Almy
    text: Names arrive after work.
    isCloseup: 1
    voiceClip: {fileID: 8300000, guid: a4303f671c6e14599b0952c69ff12e73, type: 3}
