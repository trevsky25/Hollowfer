  m_Script: {fileID: 11500000, guid: 00c9c9bb92b3b44fb84ca335c48467d8, type: 3}
  m_Name: Dialogue_Act1_MarraKitchen_FirstPayment
  m_EditorClassIdentifier: Assembly-CSharp::Hollowfen.Dialogue.DialogueData
  _id: act1.marra_kitchen.first_payment
  _lines:
  - speaker: Bram
    text: Three silver, two copper.
    isCloseup: 0
    voiceClip: {fileID: 8300000, guid: f7a58bef570a1428cb2c7f86ff0ffb45, type: 3}
  - speaker: Wren
    text: That much?
    isCloseup: 0
    voiceClip: {fileID: 8300000, guid: 13c9733fcae4e43618b2889180084b87, type: 3}
  - speaker: Bram
    text: First proper bowl we've sold in a month.
    isCloseup: 1
    voiceClip: {fileID: 8300000, guid: 1f16d4c75b29e4727b477c9311a0f884, type: 3}
  - speaker: Marra
    text: Don't look grateful. Bring better ones next time.
    isCloseup: 0
    voiceClip: {fileID: 8300000, guid: 159b256ff113141b482c2769c47a75cc, type: 3}
  - speaker: Wren
    text: That is gratitude, from you.
    isCloseup: 0
    voiceClip: {fileID: 8300000, guid: be48760e8c428400f95861bbe67a9ac2, type: 3}
  - speaker: Marra
    text: Careful.
    isCloseup: 0
    voiceClip: {fileID: 8300000, guid: 48aa19651f17d410f889d3b0b227e3f5, type: 3}
