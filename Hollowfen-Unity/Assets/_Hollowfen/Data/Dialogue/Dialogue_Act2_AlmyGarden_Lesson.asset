  m_Script: {fileID: 11500000, guid: 00c9c9bb92b3b44fb84ca335c48467d8, type: 3}
  m_Name: Dialogue_Act2_AlmyGarden_Lesson
  m_EditorClassIdentifier: Assembly-CSharp::Hollowfen.Dialogue.DialogueData
  _id: act2.almy_lessons.lesson
  _lines:
  - speaker: Almy
    text: Your grandmother taught me three things. How to read rot. How to feed it.
      How to leave enough behind.
    isCloseup: 0
  - speaker: Wren
    text: That sounds less like a lesson and more like a warning.
    isCloseup: 0
  - speaker: Almy
    text: Most useful lessons are.
    isCloseup: 0
  - speaker: Wren
    text: Why teach me now?
    isCloseup: 0
  - speaker: Almy
    text: Because you came back. Nobody else has, in twenty-six years.
    isCloseup: 1
  - speaker: Wren
    text: Then teach me properly. Start to finish.
    isCloseup: 0
  - speaker: Almy
    text: 'Do not rush growth. Rushed mushrooms teach regret.


      The beds wait by your mill wall. Two plugs of Wood Ear spawn — show me you
      listened.'
    isCloseup: 0
