  _id: act2.almy_lessons.lesson
  _lines:
  - speaker: Wren
    text: Why teach me now?
    isCloseup: 0
    voiceClip: {fileID: 8300000, guid: 2655ca6586615433e84932e93e605bf9, type: 3}
  - speaker: Almy
    text: Because you came back. Nobody else has, in twenty-six years.
    isCloseup: 1
    voiceClip: {fileID: 8300000, guid: c25dee48a71dc4340b54fdbe8c155d4f, type: 3}
  - speaker: Wren
    text: Then teach me properly. Start to finish.
    isCloseup: 0
    voiceClip: {fileID: 8300000, guid: e6bc5e6e015ce4940ad02af0168e6a19, type: 3}
