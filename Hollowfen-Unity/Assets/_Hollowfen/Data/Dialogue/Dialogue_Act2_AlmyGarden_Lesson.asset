  m_EditorHideFlags: 0
  m_Script: {fileID: 11500000, guid: 00c9c9bb92b3b44fb84ca335c48467d8, type: 3}
  m_Name: Dialogue_Act2_AlmyGarden_Lesson
  m_EditorClassIdentifier: Assembly-CSharp::Hollowfen.Dialogue.DialogueData
  _id: act2.almy_lessons.lesson
  _lines:
  - speaker: Almy
    text: Your grandmother taught me three things. How to read rot. How to feed it.
      How to leave enough behind.
    isCloseup: 0
    voiceClip: {fileID: 8300000, guid: d8fe2462b23134877901ba669f2ca812, type: 3}
  - speaker: Wren
    text: That sounds less like a lesson and more like a warning.
    isCloseup: 0
    voiceClip: {fileID: 8300000, guid: 83ebba41d0a9545a9b0838fa881bcb6f, type: 3}
  - speaker: Almy
    text: Most useful lessons are.
    isCloseup: 0
    voiceClip: {fileID: 8300000, guid: 6beb3b0b7cbbd48b1aa7857a2e628307, type: 3}
  - speaker: Wren
    text: Why teach me now?
    isCloseup: 0
    voiceClip: {fileID: 8300000, guid: c80308a5f445249909e0c66d8b3c0f7d, type: 3}
  - speaker: Almy
    text: Because you came back. Nobody else has, in twenty-six years.
    isCloseup: 1
    voiceClip: {fileID: 8300000, guid: 6c5b1f6e55f8b48f0b00b2fd48cd3e7d, type: 3}
  - speaker: Wren
    text: Then teach me properly. Start to finish.
    isCloseup: 0
    voiceClip: {fileID: 8300000, guid: d0d5b0d858a4742e7a48f0ebc3622f5d, type: 3}
  - speaker: Almy
    text: "Do not rush growth. Rushed mushrooms teach regret.\n\nThe beds wait by
      your mill wall. Two plugs of Wood Ear spawn \u2014 show me you listened."
    isCloseup: 0
    voiceClip: {fileID: 8300000, guid: 7c13e8a59f29a4f298ae4f4ed6fc2a4e, type: 3}
