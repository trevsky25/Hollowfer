  m_Script: {fileID: 11500000, guid: 00c9c9bb92b3b44fb84ca335c48467d8, type: 3}
  m_Name: Dialogue_Act3_Edda_Apprentice
  m_EditorClassIdentifier: Assembly-CSharp::Hollowfen.Dialogue.DialogueData
  _id: act3.edda.apprentice
  _lines:
  - speaker: Edda
    text: 'I would like to be apprenticed.


      Properly. Not carrying baskets.
      Not watching from paths.'
    isCloseup: 1
    voiceClip: {fileID: 8300000, guid: 8be3fab8d4267459a99f534629dd7ffa, type: 3}
  - speaker: Wren
    text: To whom?
    isCloseup: 0
    voiceClip: {fileID: 8300000, guid: 34279ad0a8d8e4f719f81ffcc7565511, type: 3}
  - speaker: Edda
    text: Do not make me say the obvious part. I practiced the other part.
    isCloseup: 0
    voiceClip: {fileID: 8300000, guid: da7ace76f8ba444238b842144ffb64ef, type: 3}
  - speaker: Wren
    text: Then say it.
    isCloseup: 0
    voiceClip: {fileID: 8300000, guid: c76363a75f89b4e43a3fdfd2984eca47, type: 3}
  - speaker: Edda
    text: 'I want to learn names, and false names, and where to cut, and when not
      to.


      Grandfather is well enough now. I asked him. He said I should stop
      hovering over his soup and go become troublesome somewhere useful.'
    isCloseup: 1
    voiceClip: {fileID: 8300000, guid: cfe8236562ac94513a69efbc5e30fa50, type: 3}
  - speaker: Wren
    text: Did you practice that?
    isCloseup: 0
    voiceClip: {fileID: 8300000, guid: f0dae9064c6b3475fbef988785fe7e96, type: 3}
  - speaker: Edda
    text: Eleven times.
    isCloseup: 0
    voiceClip: {fileID: 8300000, guid: 1ad0a99e424774e2eafd617bea921369, type: 3}
  - speaker: Wren
    text: 'It was good.


      Yes. But you start with cleaning the knife.'
    isCloseup: 0
    voiceClip: {fileID: 8300000, guid: 79dfcd9e5a4c74bbeb117792fd007cbd, type: 3}
