  m_Script: {fileID: 11500000, guid: 00c9c9bb92b3b44fb84ca335c48467d8, type: 3}
  m_Name: Dialogue_ApothecaryCase_MarraCellarBloom_Intake
  m_EditorClassIdentifier: Assembly-CSharp::Hollowfen.Dialogue.DialogueData
  _id: apothecary_case_marra_cellar_bloom_intake
  _lines:
  - speaker: Marra
    text: Three pantry jars have taken the same pale bloom. I will not feed a guess
      to the village.
    isCloseup: 0
    voiceClip: {fileID: 8300000, guid: 1cf15af9cba5c4ead906f142469af7fa, type: 3}
  - speaker: Wren
    text: We will mark the affected shelf and trace what all three jars shared.
    isCloseup: 0
    voiceClip: {fileID: 8300000, guid: e2900d11831534895aab414892d8b9f5, type: 3}
  - speaker: Edda
    text: Care begins before anyone swallows a remedy. Sometimes it begins with refusing
      a risky meal.
    isCloseup: 0
    voiceClip: {fileID: 8300000, guid: 589428692c43d437584754716cedc46d, type: 3}
