    ending: {fileID: 11400000, guid: eea24fa88644443dcbba17ac1b02b7cb, type: 2}
  - text: Accept Aldric's patronage
    next: {fileID: 0}
    setsFlagId: 
    ending: {fileID: 11400000, guid: e2658c894b9bb4a34b02ad9213f9ac38, type: 2}
