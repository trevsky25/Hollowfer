  m_EditorHideFlags: 0
  m_Script: {fileID: 11500000, guid: 00c9c9bb92b3b44fb84ca335c48467d8, type: 3}
  m_Name: Dialogue_Act4_MeetAldric
  m_EditorClassIdentifier: Assembly-CSharp::Hollowfen.Dialogue.DialogueData
  _id: act4.meet.aldric
  _lines:
  - speaker: Wren
    text: 'The manor was smaller than rumor and cleaner than kindness. He received me in an oak-paneled study with the tea already poured — not command, not threat, but civility so complete it made refusal feel rude.'
    isCloseup: 1
  - speaker: Aldric
    text: 'I should very much like to make your acquaintance, Miss Tobin.'
    isCloseup: 1
  - speaker: Wren
    text: 'You sent a letter.'
    isCloseup: 0
  - speaker: Aldric
    text: 'A letter is not an acquaintance. Merely an opening bid.'
    isCloseup: 1
  - speaker: Wren
    text: 'He listened while I spoke of the Wend. He did not deny the woodcutters. He regretted the consequence as a man regrets rain through a roof he has not personally patched.'
    isCloseup: 1
  - speaker: Aldric
    text: 'I can make Hollowfen prosperous.'
    isCloseup: 1
  - speaker: Wren
    text: 'Yes.'
    isCloseup: 0
  - speaker: Aldric
    text: 'You concede that?'
    isCloseup: 1
  - speaker: Wren
    text: 'I concede arithmetic.'
    isCloseup: 0
  - speaker: Wren
    text: 'I set the Aldermark on the polished table between us.'
    isCloseup: 1
  - speaker: Wren
    text: 'The question is what you think prosperous is allowed to cost.'
    isCloseup: 1
  - speaker: Wren
    text: 'The room went very quiet around us.'
    isCloseup: 1
