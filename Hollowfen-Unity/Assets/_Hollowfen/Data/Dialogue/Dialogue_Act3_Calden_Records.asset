  m_Script: {fileID: 11500000, guid: 00c9c9bb92b3b44fb84ca335c48467d8, type: 3}
  m_Name: Dialogue_Act3_Calden_Records
  m_EditorClassIdentifier: Assembly-CSharp::Hollowfen.Dialogue.DialogueData
  _id: act3.calden.records
  _lines:
  - speaker: Wren
    text: Wendlight where clean water ran. Sable's record names what the church chose
      to forget.
    isCloseup: 0
    voiceClip: {fileID: 8300000, guid: d9f9bb505b6364dea8267f4209246be8, type: 3}
  - speaker: Calden
    text: Then I have reading to do that I have avoided for thirty years.
    isCloseup: 1
    voiceClip: {fileID: 8300000, guid: 9df60180c016c4b77be4ae4d7c92e974, type: 3}
  - speaker: Wren
    text: You'll look?
    isCloseup: 0
    voiceClip: {fileID: 8300000, guid: f88c8a103118241098e1a11d2412b807, type: 3}
  - speaker: Calden
    text: Give me a day with the old registers. Come to the garden gate after.
    isCloseup: 0
    voiceClip: {fileID: 8300000, guid: 6f5fab58172864d2fb1064d6ea084809, type: 3}
