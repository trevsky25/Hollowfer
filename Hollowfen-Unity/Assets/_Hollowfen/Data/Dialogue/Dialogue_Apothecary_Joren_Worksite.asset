  m_Name: Dialogue_Apothecary_Joren_Worksite
  m_EditorClassIdentifier: Assembly-CSharp::Hollowfen.Dialogue.DialogueData
  _id: apothecary.joren.worksite
  _lines:
  - speaker: Joren
    text: The stone is sound. It is the hinges, flue, and table feet that have forgotten
      their work.
    isCloseup: 0
    voiceClip: {fileID: 8300000, guid: 5df0dc75a3d1f4cc6a39457a78cd8bf2, type: 3}
  - speaker: Wren
    text: Can they remember?
    isCloseup: 0
    voiceClip: {fileID: 8300000, guid: c9a91303e1c534c368e0d550c5d1fa65, type: 3}
  - speaker: Joren
    text: Wood remembers pressure. Iron remembers heat. People are the troublesome
      material.
    isCloseup: 0
    voiceClip: {fileID: 8300000, guid: 22c926325feef4efe96fa0195049a303, type: 3}
