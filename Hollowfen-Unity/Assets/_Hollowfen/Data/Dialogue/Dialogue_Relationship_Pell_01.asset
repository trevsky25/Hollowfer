  m_Script: {fileID: 11500000, guid: 00c9c9bb92b3b44fb84ca335c48467d8, type: 3}
  m_Name: Dialogue_Relationship_Pell_01
  m_EditorClassIdentifier: Assembly-CSharp::Hollowfen.Dialogue.DialogueData
  _id: relationship.pell.favor_01
  _lines:
  - speaker: Pell
    text: The cottage ledger needs names, not numbers. Joren says this is sentiment
      interfering with columns.
    isCloseup: 0
    voiceClip: {fileID: 8300000, guid: 86a414e4a30d742ffb86cf638e9bb523, type: 3}
  - speaker: Wren
    text: Joren repaired the nameplates.
    isCloseup: 0
    voiceClip: {fileID: 8300000, guid: b3938ad1e3b6b464e9fc0311fb1a73e3, type: 3}
  - speaker: Pell
    text: Precisely. His sentiment has hinges.
    isCloseup: 0
    voiceClip: {fileID: 8300000, guid: df3f8001d1eba4609be594b0b7809890, type: 3}
  - speaker: Wren
    text: Read them to me. I will make a clean copy.
    isCloseup: 1
    voiceClip: {fileID: 8300000, guid: 707250d75e0dc422da90ab104e517368, type: 3}
