  m_Name: Dialogue_Act3_Hollin_Inheritance
  m_EditorClassIdentifier: Assembly-CSharp::Hollowfen.Dialogue.DialogueData
  _id: act3.hollin.inheritance
  _lines:
  - speaker: Hollin
    text: 'My grandmother was named Sable.'
    isCloseup: 1
  - speaker: Almy
    text: 'Do not say that name carelessly.'
    isCloseup: 0
  - speaker: Wren
    text: 'You knew her.'
    isCloseup: 0
  - speaker: Almy
    text: 'I failed her. That is not the same thing.'
    isCloseup: 1
  - speaker: Hollin
    text: 'She left me half a story.'
    isCloseup: 0
  - speaker: Wren
    text: 'Then we find the other half.'
    isCloseup: 0
