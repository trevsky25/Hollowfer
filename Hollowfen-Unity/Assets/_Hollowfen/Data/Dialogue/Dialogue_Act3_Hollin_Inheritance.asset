  m_Script: {fileID: 11500000, guid: 00c9c9bb92b3b44fb84ca335c48467d8, type: 3}
  m_Name: Dialogue_Act3_Hollin_Inheritance
  m_EditorClassIdentifier: Assembly-CSharp::Hollowfen.Dialogue.DialogueData
  _id: act3.hollin.inheritance
  _lines:
  - speaker: Hollin
    text: My grandmother was named Sable.
    isCloseup: 1
    voiceClip: {fileID: 8300000, guid: 50929fdaef01d4c6488f37e811805a4d, type: 3}
  - speaker: Almy
    text: Do not say that name carelessly.
    isCloseup: 0
    voiceClip: {fileID: 8300000, guid: 1bdb86c9db37a4a979bf3ddf677323c1, type: 3}
  - speaker: Wren
    text: You knew her.
    isCloseup: 0
    voiceClip: {fileID: 8300000, guid: 24a75a692ae224224971fa6e4bd6ae6d, type: 3}
  - speaker: Almy
    text: I failed her. That is not the same thing.
    isCloseup: 1
    voiceClip: {fileID: 8300000, guid: 8bb1e8ad421964c028ab3f72df6ae05a, type: 3}
  - speaker: Hollin
    text: She left me half a story.
    isCloseup: 0
    voiceClip: {fileID: 8300000, guid: 0302fb5acfb034de0a8600eaa67e54a5, type: 3}
  - speaker: Wren
    text: Then we find the other half.
    isCloseup: 0
    voiceClip: {fileID: 8300000, guid: fe440d8c3e56e4a619235e4c56d82138, type: 3}
