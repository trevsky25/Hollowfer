  m_Name: Dialogue_Relationship_Pell_02
  m_EditorClassIdentifier: Assembly-CSharp::Hollowfen.Dialogue.DialogueData
  _id: relationship.pell.favor_02
  _lines:
  - speaker: Pell
    text: I inspect occupied cottages differently now. A sound roof matters. So does
      whether anyone sings beneath it.
    isCloseup: 0
    voiceClip: {fileID: 8300000, guid: ad85fbfef21574276a6f4300c5121311, type: 3}
  - speaker: Wren
    text: Is singing in the official form?
    isCloseup: 0
    voiceClip: {fileID: 8300000, guid: aafa5ffca803b4000897ba39ad231f3a, type: 3}
  - speaker: Pell
    text: It is in the margin. Edda has made the margins increasingly difficult to
      ignore.
    isCloseup: 0
    voiceClip: {fileID: 8300000, guid: b6dcfbb592712446090bc12c350f905e, type: 3}
  - speaker: Wren
    text: Let us walk them before the ink dries.
    isCloseup: 1
    voiceClip: {fileID: 8300000, guid: 49181e78da63048cda779b81db4e789d, type: 3}
